package strategies

import (
	"sync"
	"time"

	"github.com/jagjeet-singh-23/rate-limiter/internal/config"
	"github.com/jagjeet-singh-23/rate-limiter/internal/shared/entities"
)

type LeakyBucket struct {
	requestQueue []*entities.RequestContext
	config       config.RateLimitConfig
	mu           sync.RWMutex
}

func NewLeakyBucket(config config.RateLimitConfig) *LeakyBucket {
	return &LeakyBucket{
		// Slice starts empty but preallocated with capacity
		requestQueue: make([]*entities.RequestContext, 0, int(config.MaxCapacity)),
		config:       config,
	}
}

// Allow checks if request is allowed according to the leaky bucket algorithm.
func (b *LeakyBucket) Allow(ctx *entities.RequestContext) (bool, time.Duration) {
	b.mu.Lock()
	defer b.mu.Unlock()

	b.cleanup()

	if len(b.requestQueue) >= int(b.config.MaxCapacity) {
		leakInterval := time.Duration(float64(time.Second) / float64(b.config.RefillRate))
		oldest := b.requestQueue[0]
		retryAfter := max(0, time.Until(oldest.Timestamp.Add(leakInterval)))
		return false, retryAfter
	}

	b.requestQueue = append(b.requestQueue, ctx)
	return true, 0
}

// cleanup removes expired requests from the queue.
// This is not thread-safe and MUST be called with a lock held.
func (b *LeakyBucket) cleanup() {
	now := time.Now()
	// Each request occupies capacity for at least 1.0/RefillRate seconds.
	leakInterval := time.Duration(float64(time.Second) / float64(b.config.RefillRate))
	cutoffTime := now.Add(-leakInterval)

	firstValidIdx := len(b.requestQueue)
	for i, req := range b.requestQueue {
		if req.Timestamp.After(cutoffTime) {
			firstValidIdx = i
			break
		}
	}

	// Avoid memory leaks by nil-ing out processed request pointers before slicing.
	for i := 0; i < firstValidIdx; i++ {
		b.requestQueue[i] = nil
	}
	b.requestQueue = b.requestQueue[firstValidIdx:]
}

func (b *LeakyBucket) canAcceptRequest() (bool, time.Duration) {
	b.mu.RLock()
	defer b.mu.RUnlock()

	if len(b.requestQueue) >= int(b.config.MaxCapacity) {
		leakInterval := time.Duration(float64(time.Second) / float64(b.config.RefillRate))
		oldest := b.requestQueue[0]
		retryAfter := time.Until(oldest.Timestamp.Add(leakInterval))
		if retryAfter < 0 {
			retryAfter = 0
		}
		return false, retryAfter
	}

	return true, 0
}
